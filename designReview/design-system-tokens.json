{
  "$name": "農業數位整合服務平臺 — Design System Tokens",
  "$version": "1.2.0",
  "$audit": {
    "date": "2026-04-24",
    "sources": [
      "design-specs/Colors.png",
      "design-specs/Typography.png",
      "design-specs/Button.png",
      "design-specs/Shadow.png",
      "design-specs/WEB_首頁 2.png",
      "design-specs/WEB_會員登入.png",
      "design-specs/WEB_一般會員02.png",
      "design-specs/WEB_線上申請服務01.png"
    ],
    "notes": "色碼為從設計稿圖檔目測估算值，正式使用前請與設計師確認精確色碼。新增 4 張 WEB 頁面設計稿，驗證了色彩/字體/按鈕/表單在實際頁面中的使用情況。",
    "specs": [
      {
        "file": "Colors.png",
        "type": "component-spec",
        "summary": "主色×2（teal green + orange）各 9 階 + 灰階 9 階 + 語意色 danger",
        "findings": [
          { "s": "pass", "t": "主色一 teal green 9 階漸層完整（900–100）" },
          { "s": "pass", "t": "主色二 orange 9 階漸層完整（900–100）" },
          { "s": "pass", "t": "中性灰 gray 9 階完整（900–100）" },
          { "s": "pass", "t": "語意色 danger（紅色）已定義" },
          { "s": "warn", "t": "色票無 HEX 色碼標示" },
          { "s": "fail", "t": "缺 success / warning / info 語意色" },
          { "s": "fail", "t": "缺背景（background）/ 前景（foreground）配對定義" }
        ]
      },
      {
        "file": "Typography.png",
        "type": "component-spec",
        "summary": "Noto Sans TC + Geologica，H1–H6 + Body 含行高與 mobile size",
        "findings": [
          { "s": "pass", "t": "中文字型 Noto Sans TC 已指定" },
          { "s": "pass", "t": "英文字型 Geologica 已指定" },
          { "s": "pass", "t": "H1–H6 + Body 字級定義含行高" },
          { "s": "pass", "t": "含 Mobile size 響應式定義" },
          { "s": "warn", "t": "缺 Caption / Overline 層級" },
          { "s": "fail", "t": "無 fallback 字型指定（如系統字型後備）" }
        ]
      },
      {
        "file": "Button.png",
        "type": "component-spec",
        "summary": "Primary / Secondary filled + outlined + Disabled + Text button",
        "findings": [
          { "s": "pass", "t": "Primary filled + outlined 雙版本" },
          { "s": "pass", "t": "Secondary filled + outlined 雙版本" },
          { "s": "pass", "t": "Disabled 狀態已定義" },
          { "s": "pass", "t": "Text button 類型已定義" },
          { "s": "warn", "t": "白字 on 綠色按鈕對比度 ≈ 3:1（AA 需 4.5:1）" },
          { "s": "fail", "t": "缺 Hover / Active / Focus ring 互動狀態" },
          { "s": "fail", "t": "缺 Loading 與 Danger 變體" }
        ]
      },
      {
        "file": "Shadow.png",
        "type": "component-spec",
        "summary": "僅定義 Medium 1 級陰影",
        "findings": [
          { "s": "pass", "t": "Medium 級別陰影已定義，含參數值" },
          { "s": "fail", "t": "僅 1 級，缺 low / high 層級系統" }
        ]
      },
      {
        "file": "WEB_首頁 2.png",
        "type": "page-mockup",
        "summary": "完整首頁：Header / Hero / 公告輪播 / 補助卡片 / 活動 / 新聞 / Footer",
        "findings": [
          { "s": "pass", "t": "完整首頁結構含 Header、Hero、公告、補助、活動、新聞、Footer" },
          { "s": "pass", "t": "綠色品牌調性統一，色彩使用與 Colors.png 一致" },
          { "s": "pass", "t": "多種按鈕類型實際運用：Primary / Outlined / Tag / Ghost" },
          { "s": "pass", "t": "字級層級與 Typography.png 對應（標題/副標/內文/按鈕）" },
          { "s": "pass", "t": "觀察到一致的 8px 基準間距模式" },
          { "s": "warn", "t": "圖示以 Outline 為主但混用 Filled + Emoji 風格" },
          { "s": "warn", "t": "按鈕圓角不統一（查詢按鈕 8px vs Header 膠囊形）" },
          { "s": "fail", "t": "按鈕僅呈現 Default 狀態，缺 Hover / Active" },
          { "s": "fail", "t": "Hero 區域白色文字在背景圖上對比不足" },
          { "s": "fail", "t": "無 Focus indicator（鍵盤導航不可見）" }
        ]
      },
      {
        "file": "WEB_會員登入.png",
        "type": "page-mockup",
        "summary": "登入頁面：帳號/密碼/驗證碼 + LINE 登入 + QR Code",
        "findings": [
          { "s": "pass", "t": "帳號 / 密碼 / 驗證碼輸入欄位完整" },
          { "s": "pass", "t": "LINE 登入 + QR Code 登入流程" },
          { "s": "pass", "t": "Header 含搜尋框元件" },
          { "s": "warn", "t": "CAPTCHA 驗證碼圖片無替代方案（無障礙風險）" },
          { "s": "warn", "t": "連結文字僅靠顏色區分，無底線輔助" },
          { "s": "fail", "t": "🚨 白字 on 綠色按鈕對比度 ≈ 3:1（WCAG AA 需 4.5:1）" },
          { "s": "fail", "t": "表單僅 Default 狀態，缺 Focus / Error / Disabled" },
          { "s": "fail", "t": "無 Focus indicator" }
        ]
      },
      {
        "file": "WEB_一般會員02.png",
        "type": "page-mockup",
        "summary": "Step 2 帳號設定：手機輸入 + Error 文字 + 步驟指示器",
        "findings": [
          { "s": "pass", "t": "步驟式表單 Step 2 帳號設定結構完整" },
          { "s": "pass", "t": "深綠側邊欄步驟指示器（Step 1–5）" },
          { "s": "pass", "t": "手機輸入框含錯誤訊息文字（首次見到 Error 狀態）" },
          { "s": "warn", "t": "Error 狀態僅有文字提示，輸入框邊框未變紅色" },
          { "s": "fail", "t": "缺 Focus / Disabled / Success 表單狀態" },
          { "s": "fail", "t": "無 Focus indicator" }
        ]
      },
      {
        "file": "WEB_線上申請服務01.png",
        "type": "page-mockup",
        "summary": "線上申請服務：搜尋篩選 + 服務卡片列表 + 分頁",
        "findings": [
          { "s": "pass", "t": "搜尋篩選功能 + 服務卡片列表 + 分頁元件" },
          { "s": "pass", "t": "到期警告標籤使用 Warning 橘色（#F57C00）" },
          { "s": "pass", "t": "自訂 Radio 與 Tag 篩選元件" },
          { "s": "warn", "t": "卡片陰影極輕，整體扁平風格（與 Shadow.png 定義不一致）" },
          { "s": "fail", "t": "篩選元件僅 Default 狀態，缺互動回饋" },
          { "s": "fail", "t": "無 Focus indicator" }
        ]
      }
    ]
  },
